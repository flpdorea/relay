{
  "name": "relay",
  "version": "1.0.0",
  "description": "A production-ready HTTP load balancer built with Node.js and TypeScript",
  "main": "dist/cli/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node --esm src/cli/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-pattern \"*.d.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-pattern \"*.d.ts\"",
    "test-server": "ts-node --esm src/testServer/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "load-balancer",
    "http",
    "proxy",
    "round-robin",
    "health-check",
    "typescript"
  ],
  "author": "@flpdorea",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
